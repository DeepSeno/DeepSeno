# DeepSeno Desktop App — Environment Configuration
# Copy this file to .env and fill in your values for local development.

# ── Backend API (required) ───────────────────────────
# Your backend API base URL (must be set for cloud sync / relay features)
API_BASE_URL=https://your-server.example.com/api/v1

# CDN base URL for model downloads
CDN_BASE_URL=https://your-cdn.example.com

# ── macOS Release (maintainers only) ──────────────────
# Apple notarization credentials
# APPLE_API_KEY=/path/to/AuthKey_XXXXXXXX.p8
# APPLE_API_KEY_ID=XXXXXXXXXX
# APPLE_API_ISSUER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── HuggingFace Token ─────────────────────────────────
# Set by user in Settings UI (stored encrypted via Electron safeStorage).
# Not needed at build time — removed from build injection.
